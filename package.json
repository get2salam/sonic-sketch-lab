{
  "name": "sonic-sketch-lab",
  "version": "0.1.0",
  "description": "Browser-based Web Audio sketchpad for composing tiny synth loops with TypeScript, Vite, sequencer logic, visualizer, and PWA shell",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node scripts/smoke.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "^8.1.0",
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^25.0.1",
    "@types/node": "^22.15.0",
    "workbox-window": "^7.3.0"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "web-audio",
    "sequencer",
    "synthesizer",
    "typescript",
    "vite",
    "pwa"
  ],
  "license": "MIT"
}
